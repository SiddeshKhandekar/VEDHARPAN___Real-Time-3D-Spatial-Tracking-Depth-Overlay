# ==============================================================================
# CUSTOM PROJECT RULES: Computer Vision, MediaPipe & UI Overlay
# ==============================================================================

# --- IDE & OS Clutter ---
# Ignore workspace folders and system thumbnail caches
.vscode/ 
.idea/ 
*.swp
*.swo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Computer Vision & Media Test Files ---
# Prevent local webcam test recordings or raw frame dumps from inflating git history
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.jpg
*.jpeg
*.png
# EXCEPTION: Allow tracking of promotional logos, UI icons, or demo videos inside an assets folder
!/assets/*

# --- Model Data & Depth Calibration Cache ---
# Ignore local matrix calibrations, baseline z-depth saves, and downloaded ML weights
*.dat
*.pkl
*.h5
*.tflite
*.onnx
calibrations/
*.log
